{
  "name": "restaurants-finder",
  "version": "1.0.0",
  "description": "Restaurant locations finder API built with Fastify",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test:db:prepare": "tsx tests/test-database.ts",
    "test": "npm run test:db:prepare && vitest run",
    "typeorm": "tsx ./node_modules/typeorm/cli.js -d src/database/data-source.ts",
    "seed": "tsx src/database/seeds/run-seeds.ts",
    "lint": "eslint . --fix && prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [],
  "license": "MIT",
  "dependencies": {
    "@fastify/jwt": "^9.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.2",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.11.1",
    "pg": "^8.16.0",
    "reflect-metadata": "^0.2.2",
    "stream-chain": "^4.2.3",
    "stream-json": "^3.3.0",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.15.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^3.1.4"
  }
}
